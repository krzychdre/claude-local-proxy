{
  "name": "claude-code-model-router",
  "version": "1.0.0",
  "private": true,
  "description": "Model-aware routing proxy for Claude Code — sends local-tier models to your own LLM, everything else to the real Anthropic API.",
  "type": "module",
  "main": "router.mjs",
  "bin": {
    "claude-router": "router.mjs"
  },
  "scripts": {
    "start": "node router.mjs",
    "test": "node tests/run.mjs",
    "build": "make build",
    "build:install": "make install"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "router.mjs",
    "router.config.example.json",
    "start.sh",
    "tests/"
  ]
}